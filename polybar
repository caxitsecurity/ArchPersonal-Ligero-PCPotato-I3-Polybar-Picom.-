[colors]
background = #55282a36
foreground = #f8f8f2
gray = #44475a
cyan = #8be9fd
green = #50fa7b
orange = #ffb86c
pink = #ff79c6
purple = #bd93f9
red = #ff5555
yellow = #f1fa8c

[bar/main]
monitor = DP-1

width = 1600
height = 38
radius = 7
offset-x = 160
offset-y = 5

background = ${colors.background}
foreground = ${colors.foreground}

padding-left = 2
padding-right = 3
module-margin = 1

border-size = 2
border-color = #55bd93f9
font-0 = JetBrainsMono Nerd Font:size=10;2
font-1 = JetBrainsMono Nerd Font:size=12;3

wm-restack = i3
override-redirect = true
fixed-center = true

modules-left = logo i3 sep date sep player
modules-center =
modules-right = cpu sep memory sep pulseaudio sep ip sep networkicon sep shield

enable-ipc = true

[module/logo]
type = custom/text
format = ""
format-foreground = ${colors.purple}
format-padding = 2

[module/sep]
type = custom/text
format = "|"
format-foreground = ${colors.gray}
format-padding = 1

[module/i3]
type = internal/i3
format = <label-state>

index-sort = true
wrapping-scroll = false

label-focused = %index%
label-focused-background = ${colors.purple}
label-focused-foreground = #282a36
label-focused-padding = 1

label-unfocused = %index%
label-unfocused-foreground = ${colors.foreground}
label-unfocused-padding = 1

label-visible = %index%
label-visible-foreground = ${colors.cyan}
label-visible-padding = 1

label-urgent = %index%
label-urgent-background = ${colors.red}
label-urgent-foreground = ${colors.foreground}
label-urgent-padding = 1

[module/date]
type = internal/date
interval = 1
date =   %H:%M  •  %d-%m-%Y
label = %date%
label-foreground = ${colors.yellow}

[module/player]
type = custom/script
exec = ~/.config/polybar/scripts/player.sh
interval = 2
format = <label>
label = %output%
label-maxlen = 40
label-foreground = ${colors.green}
click-left = playerctl play-pause
click-right = playerctl next
click-middle = playerctl previous

[module/cpu]
type = internal/cpu
interval = 2
label = CPU %percentage%%
label-foreground = ${colors.orange}

[module/memory]
type = internal/memory
interval = 2
label = RAM %percentage_used%%
label-foreground = ${colors.pink}

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume>
label-volume = VOL %percentage%%
label-volume-foreground = ${colors.cyan}

format-muted = <label-muted>
label-muted = MUTED
label-muted-foreground = ${colors.red}

[module/ip]
type = custom/script
exec = ip route get 1.1.1.1 2>/dev/null | awk '{print "IP " $7; exit}'
interval = 5
format = <label>
label = %output%
label-foreground = ${colors.green}

[module/networkicon]
type = custom/text
format = ""
format-foreground = ${colors.cyan}
format-padding = 1
click-left = nm-connection-editor
click-right = alacritty -e nmtui

[module/shield]
type = custom/script
exec = ~/.config/polybar/scripts/shield.sh
interval = 10
format = <label>
label = %output%
label-foreground = ${colors.purple}
